# Andex Gateway - Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Centro/Hospital
CENTRO_NOMBRE=Mi Centro Médico
CENTRO_ID=centro-001

# Security
API_KEY=your-secret-api-key-here
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=admin123

# CORS - Origins permitidos (separados por coma)
ALLOWED_ORIGINS=https://andexreports.app,http://localhost:5173

# Orthanc Connection
ORTHANC_URL=http://localhost:8042
ORTHANC_USERNAME=
ORTHANC_PASSWORD=

# Queue Settings
RETRY_INTERVAL_MS=60000
MAX_RETRY_ATTEMPTS=5
CLEANUP_AFTER_HOURS=24

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
