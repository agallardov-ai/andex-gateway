# ANDEX GATEWAY - Variables de Entorno
#
# Copie este archivo a .env y configure segun su centro.
# Tambien puede usar: ./setup.sh (asistente interactivo)

# ===== IDENTIDAD DEL CENTRO =====
CENTRO_NOMBRE=Mi Hospital
CENTRO_ID=mi-hospital

# ===== GATEWAY =====
PORT=3001
NODE_ENV=production

# ===== SEGURIDAD =====
# API Key para autenticar requests (genere con: openssl rand -hex 32)
API_KEY=cambie-esta-api-key
# Credenciales del Dashboard web
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=cambie-esta-clave
# Origenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=https://andexreports.app,http://localhost:5173,http://localhost:3000

# ===== PACS =====
# Tipo: orthanc | dicomweb
PACS_TYPE=orthanc
# URL base del servidor PACS
PACS_BASE_URL=http://localhost:8042

# Autenticacion: none | basic | bearer
PACS_AUTH_TYPE=none
# Para basic auth:
PACS_USERNAME=
PACS_PASSWORD=
# Para bearer auth:
PACS_TOKEN=

# ===== DICOMweb ENDPOINTS =====
# Solo relevante si PACS_TYPE=dicomweb
PACS_STOW_ENDPOINT=/dicomweb/studies
PACS_QIDO_ENDPOINT=/dicomweb/studies
PACS_WADO_ENDPOINT=/dicomweb/studies

# ===== WORKLIST =====
# Modo: pacs | mock
WORKLIST_MODE=mock
WORKLIST_ENDPOINT=/modalities
WORKLIST_MWL_ENDPOINT=/modalities
# Preferir UPS (Unified Procedure Step) sobre MWL
WORKLIST_PREFER_UPS=false
# Modalidad por defecto para filtrar worklist
WORKLIST_DEFAULT_MODALITY=ES

# ===== WORKLIST SYNC =====
WORKLIST_SYNC_ENABLED=true
WORKLIST_SYNC_INTERVAL_MS=30000
WORKLIST_DEFAULT_BOX_ID=
WORKLIST_DEFAULT_CENTRO_ID=

# ===== STORAGE =====
# Ruta para almacenar archivos DICOM (pending/processed/failed)
STORAGE_PATH=./data

# ===== COLA DE REINTENTOS =====
QUEUE_RETRY_INTERVAL=5000
QUEUE_MAX_RETRIES=5
# Horas antes de limpiar archivos procesados
CLEANUP_AFTER_HOURS=48

# ===== RATE LIMITING =====
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ===== SUPABASE (sync cloud) =====
# Generado por andexreports.app/nuevocentro
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_CENTRO_TOKEN=
# Legacy (migrar a ANON_KEY + CENTRO_TOKEN):
# SUPABASE_SERVICE_KEY=
